{
  "schemaVersion": 1,
  "id": "aliyun",
  "platform": "aliyun-thoughts",
  "name": "阿里云 Thoughts",
  "title": "阿里云 Thoughts 工作区导出",
  "navLabel": "阿里云 Thoughts 导出",
  "description": "读取 Thoughts 工作区目录并导出 Markdown、图片和目录结构。",
  "type": "automation",
  "group": "export",
  "trustLevel": "official",
  "status": "stable",
  "templateId": "template-aliyun",
  "defaults": { "output": "exports/aliyun-thoughts", "delay": "0.1", "jitter": "0" },
  "capabilities": { "export": true, "import": false, "guide": false, "login": true, "scanToc": true, "images": true, "attachments": false, "tree": true, "batch": true, "retryFailures": true },
  "checkpoint": { "supported": true, "strategy": "items", "resourceTracking": false },
  "retryFailures": { "arg": "--retry-failed", "label": "只重试失败项" },
  "toc": { "itemsPath": "nodes", "idKey": "id", "exportIdKey": "id", "titleKey": "title", "parentIdKey": "parent_id", "typeKey": "type", "selectableTypes": ["document"], "selectionArg": "--doc-id", "selectableWhenExportId": true },
  "fields": [
    { "name": "workspace_url", "label": "Thoughts 工作区 URL", "type": "text", "arg": "--workspace-url", "required": true, "history": "url", "actions": ["login", "scan", "export"] },
    { "name": "output", "label": "输出目录", "type": "directory", "arg": "--output", "required": true, "history": "path", "actions": ["export"] },
    { "name": "incremental", "label": "增量导出", "type": "checkbox", "arg": "--incremental", "default": true, "advanced": true, "actions": ["export"] },
    { "name": "update_existing", "label": "更新已有文档", "type": "checkbox", "arg": "--update-existing", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "retry_failed", "label": "只重试失败项", "type": "checkbox", "arg": "--retry-failed", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "request_delay", "label": "请求延迟秒", "type": "number", "arg": "--request-delay", "default": 0.1, "min": 0, "step": 0.1, "advanced": true, "actions": ["export"] },
    { "name": "request_jitter", "label": "随机浮动秒", "type": "number", "arg": "--request-jitter", "default": 0, "min": 0, "step": 0.1, "advanced": true, "actions": ["export"] }
  ],
  "actions": [
    { "id": "login", "kind": "login", "label": "登录并保存凭证", "script": "../../backend/export_aliyun_thoughts.py", "args": ["--login"], "track": false, "secondary": true },
    { "id": "scan", "kind": "scan", "label": "读取工作区目录", "script": "../../backend/export_aliyun_thoughts.py", "args": ["--scan-toc"], "includeSelection": false, "secondary": true },
    { "id": "export", "kind": "export", "label": "开始导出", "script": "../../backend/export_aliyun_thoughts.py", "args": ["--progress-every", "1"], "progressTitle": "阿里云 Thoughts 导出", "progressDetail": "正在导出目录、正文和图片..." }
  ]
}
