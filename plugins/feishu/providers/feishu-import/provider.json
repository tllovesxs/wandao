{
  "schemaVersion": 1,
  "id": "feishu-import",
  "platform": "feishu",
  "name": "飞书",
  "title": "Markdown 导入飞书 Wiki",
  "navLabel": "飞书导入",
  "description": "通过飞书 OpenAPI 批量导入本地 Markdown，修复图片并移动到目标 Wiki。",
  "type": "hybrid",
  "group": "import",
  "trustLevel": "official",
  "status": "stable",
  "guide": "README.md",
  "tags": ["导入", "Wiki", "图片补全", "权限检测"],
  "capabilities": { "export": false, "import": true, "guide": true, "login": true, "scanToc": false, "images": true, "attachments": true, "tree": true, "batch": true, "retryFailures": true },
  "checkpoint": { "supported": true, "strategy": "items", "resourceTracking": false },
  "retryFailures": { "arg": "--retry-failed", "label": "只重试失败项" },
  "fields": [
    { "name": "wiki_url", "label": "目标飞书 Wiki URL", "type": "text", "arg": "--wiki-url", "required": true, "placeholder": "https://xxx.feishu.cn/wiki/...", "actions": ["login", "probe", "plan", "import", "setupTarget"] },
    { "name": "source_dir", "label": "本地 Markdown 目录", "type": "directory", "arg": "--source-dir", "required": true, "actions": ["plan", "import"] },
    { "name": "app_id", "label": "飞书应用 App ID（留空读取已保存配置）", "type": "text", "arg": "--app-id", "actions": ["saveConfig", "checkApp", "permissions", "probe", "plan", "import", "setupTarget"] },
    { "name": "app_secret", "label": "飞书应用 App Secret（留空读取已保存配置）", "type": "password", "arg": "--app-secret", "actions": ["saveConfig", "checkApp", "probe", "plan", "import", "setupTarget"] },
    { "name": "drive_folder_token", "label": "云空间目录 Token（可选）", "type": "text", "arg": "--drive-folder-token", "advanced": true, "actions": ["saveConfig", "plan", "import"] },
    { "name": "import_mount_key", "label": "导入挂载 Key（可选）", "type": "text", "arg": "--import-mount-key", "advanced": true, "actions": ["saveConfig", "import"] },
    { "name": "space_id", "label": "目标 Wiki Space ID（可自动检测）", "type": "text", "arg": "--space-id", "advanced": true, "actions": ["saveConfig", "import", "setupTarget"] },
    { "name": "parent_wiki_token", "label": "父级 Wiki Token（可自动检测）", "type": "text", "arg": "--parent-wiki-token", "advanced": true, "actions": ["saveConfig", "import", "setupTarget"] },
    { "name": "obj_type", "label": "导入文档类型", "type": "select", "arg": "--obj-type", "default": "docx", "options": [{ "value": "docx", "label": "新版文档 docx" }, { "value": "doc", "label": "旧版文档 doc" }], "advanced": true, "actions": ["saveConfig", "import"] },
    { "name": "max_import", "label": "最多导入篇数（0 为全部）", "type": "number", "arg": "--max-import", "default": 0, "min": 0, "advanced": true, "actions": ["import"] },
    { "name": "move_to_wiki", "label": "导入后移动到目标 Wiki", "type": "checkbox", "arg": "--move-to-wiki", "default": true, "advanced": true, "actions": ["import"] },
    { "name": "require_image_repair", "label": "图片补全失败时判定导入失败", "type": "checkbox", "arg": "--require-image-repair", "default": false, "advanced": true, "actions": ["import"] },
    { "name": "skip_image_repair", "label": "跳过本地图片补全", "type": "checkbox", "arg": "--skip-image-repair", "default": false, "advanced": true, "actions": ["import"] },
    { "name": "skip_rename", "label": "保留飞书临时标题，不恢复 Markdown 标题", "type": "checkbox", "arg": "--skip-rename", "default": false, "advanced": true, "actions": ["import"] },
    { "name": "image_max_width", "label": "图片最大显示宽度", "type": "number", "arg": "--image-max-width", "default": 1200, "min": 100, "advanced": true, "actions": ["import"] },
    { "name": "poll_timeout", "label": "异步任务超时秒", "type": "number", "arg": "--poll-timeout", "default": 120, "min": 10, "advanced": true, "actions": ["import"] },
    { "name": "poll_interval", "label": "异步任务轮询秒", "type": "number", "arg": "--poll-interval", "default": 2, "min": 0.5, "step": 0.5, "advanced": true, "actions": ["import"] },
    { "name": "request_delay", "label": "请求延迟秒", "type": "number", "arg": "--request-delay", "default": 0.5, "min": 0, "step": 0.1, "advanced": true, "actions": ["plan", "import"] },
    { "name": "request_jitter", "label": "随机浮动秒", "type": "number", "arg": "--request-jitter", "default": 0.3, "min": 0, "step": 0.1, "advanced": true, "actions": ["plan", "import"] }
  ],
  "actions": [
    { "id": "login", "kind": "login", "label": "登录飞书网页版", "script": "../../backend/import_feishu.py", "args": ["--login"], "includeSelection": false, "track": false, "secondary": true },
    { "id": "saveConfig", "kind": "custom", "label": "保存 API 配置", "script": "../../backend/import_feishu.py", "args": ["--save-config"], "secondary": true, "track": false },
    { "id": "checkApp", "kind": "check", "label": "检测应用配置", "script": "../../backend/import_feishu.py", "args": ["--check-app-setup"], "secondary": true, "track": false },
    { "id": "permissions", "kind": "check", "label": "检查并开通权限", "script": "../../backend/import_feishu.py", "args": ["--setup-openapi-permissions"], "secondary": true, "track": false },
    { "id": "probe", "kind": "check", "label": "检测目标 Wiki", "script": "../../backend/import_feishu.py", "args": ["--probe"], "secondary": true, "track": false },
    { "id": "setupTarget", "kind": "check", "label": "添加应用到目标 Wiki", "script": "../../backend/import_feishu.py", "args": ["--setup-target-wiki-doc-app"], "secondary": true, "track": false },
    { "id": "plan", "kind": "plan", "label": "生成导入计划", "script": "../../backend/import_feishu.py", "args": ["--plan"], "secondary": true, "track": false },
    { "id": "import", "kind": "import", "label": "开始导入", "script": "../../backend/import_feishu.py", "args": ["--api-import-all", "--yes"], "progressTitle": "Markdown 导入飞书", "progressDetail": "正在上传文档、修复图片并写入 Wiki..." }
  ]
}
