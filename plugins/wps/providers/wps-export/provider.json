{
  "schemaVersion": 1,
  "id": "wps-export",
  "platform": "wps",
  "name": "WPS \u6587\u6863",
  "title": "WPS \u667a\u80fd\u6587\u6863 Markdown \u53ca\u5176\u4ed6\u6587\u6863\u539f\u59cb\u6587\u4ef6\u5bfc\u51fa",
  "navLabel": "WPS \u6587\u6863\u5bfc\u51fa",
  "description": "\u901a\u8fc7\u72ec\u7acb\u6d4f\u89c8\u5668\u767b\u5f55\uff0c\u626b\u63cf WPS \u4e91\u6587\u6863\uff1a\u667a\u80fd\u6587\u6863\u8f6c\u6362\u4e3a Markdown\uff0c\u5176\u4ed6\u6587\u6863\u4fdd\u7559\u539f\u59cb\u6587\u4ef6\uff0c\u4e0d\u8bfb\u53d6\u8bbe\u5907\u6587\u6863\u3002",
  "type": "automation",
  "group": "export",
  "trustLevel": "experimental",
  "status": "experimental",
  "homepage": "https://docs.wps.cn/welcome",
  "defaults": {
    "output": "exports/wps",
    "request_delay": 0.1
  },
  "capabilities": {
    "export": true,
    "import": false,
    "guide": false,
    "login": true,
    "scanToc": true,
    "images": false,
    "attachments": true,
    "tree": true,
    "batch": true,
    "retryFailures": true
  },
  "checkpoint": {
    "supported": true,
    "strategy": "items",
    "resourceTracking": false
  },
  "retryFailures": {
    "arg": "--retry-failed",
    "label": "\u53ea\u91cd\u8bd5\u5931\u8d25\u9879"
  },
  "toc": {
    "itemsPath": "nodes",
    "idKey": "id",
    "exportIdKey": "file_id",
    "titleKey": "title",
    "parentIdKey": "parent_id",
    "typeKey": "type",
    "selectableTypes": [
      "file"
    ],
    "selectionArg": "--file-id",
    "selectableWhenExportId": true
  },
  "fields": [
    {
      "name": "output",
      "label": "\u8f93\u51fa\u76ee\u5f55",
      "type": "directory",
      "arg": "--output",
      "required": true,
      "default": "exports/wps",
      "actions": [
        "export"
      ]
    },
    {
      "name": "request_delay",
      "label": "\u8bf7\u6c42\u5ef6\u8fdf\uff08\u79d2\uff09",
      "type": "number",
      "arg": "--request-delay",
      "default": 0.1,
      "min": 0,
      "step": 0.1,
      "advanced": true,
      "actions": [
        "scan",
        "export"
      ]
    },
    {
      "name": "retry_failed",
      "label": "\u53ea\u91cd\u8bd5\u5931\u8d25\u9879",
      "type": "checkbox",
      "arg": "--retry-failed",
      "default": false,
      "advanced": true,
      "actions": [
        "export"
      ]
    }
  ],
  "actions": [
    {
      "id": "login",
      "kind": "login",
      "label": "\u767b\u5f55 WPS \u5e76\u4fdd\u5b58\u8ba4\u8bc1",
      "script": "../../backend/export_wps.py",
      "args": [
        "--login"
      ],
      "track": false,
      "secondary": true
    },
    {
      "id": "scan",
      "kind": "scan",
      "label": "\u626b\u63cf WPS \u6587\u6863",
      "script": "../../backend/export_wps.py",
      "args": [
        "--scan-toc"
      ],
      "includeSelection": false,
      "secondary": true
    },
    {
      "id": "export",
      "kind": "export",
      "label": "\u5f00\u59cb\u5bfc\u51fa",
      "script": "../../backend/export_wps.py",
      "args": [
        "--progress-every",
        "1"
      ],
      "progressTitle": "WPS \u6587\u6863\u5bfc\u51fa",
      "progressDetail": "\u6b63\u5728\u5bfc\u51fa WPS \u667a\u80fd\u6587\u6863 Markdown \u53ca\u5176\u4ed6\u6587\u6863\u539f\u59cb\u6587\u4ef6..."
    },
    {
      "id": "clearAuth",
      "kind": "custom",
      "label": "\u6e05\u9664 WPS \u767b\u5f55\u72b6\u6001",
      "script": "../../backend/export_wps.py",
      "args": [
        "--clear-auth"
      ],
      "track": false,
      "secondary": true,
      "danger": true,
      "confirm": "\u8fd9\u4f1a\u5220\u9664\u672c\u673a\u4fdd\u5b58\u7684 WPS \u767b\u5f55\u72b6\u6001\uff0c\u4e0d\u4f1a\u5220\u9664\u5df2\u5bfc\u51fa\u6587\u4ef6\u3002\u786e\u5b9a\u7ee7\u7eed\u5417\uff1f"
    }
  ]
}
