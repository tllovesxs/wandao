{
  "schemaVersion": 1,
  "id": "wps-export",
  "platform": "wps",
  "name": "WPS 云文档",
  "title": "WPS“我的云文档”原始文件导出",
  "navLabel": "WPS 云文档导出",
  "description": "通过独立浏览器登录，扫描并导出“我的云文档”中的可下载原始文件。",
  "type": "automation",
  "group": "export",
  "trustLevel": "experimental",
  "status": "experimental",
  "guide": "README.md",
  "homepage": "https://www.kdocs.cn/latest",
  "defaults": {
    "output": "exports/wps",
    "request_delay": 0.1
  },
  "capabilities": {
    "export": true,
    "import": false,
    "guide": true,
    "login": true,
    "scanToc": true,
    "images": false,
    "attachments": true,
    "tree": true,
    "batch": true,
    "retryFailures": true
  },
  "checkpoint": {
    "supported": true,
    "strategy": "items",
    "resourceTracking": false
  },
  "retryFailures": {
    "arg": "--retry-failed",
    "label": "只重试失败项"
  },
  "toc": {
    "itemsPath": "nodes",
    "idKey": "id",
    "exportIdKey": "file_id",
    "titleKey": "title",
    "parentIdKey": "parent_id",
    "typeKey": "type",
    "selectableTypes": [
      "file"
    ],
    "selectionArg": "--file-id",
    "selectableWhenExportId": true
  },
  "fields": [
    {
      "name": "output",
      "label": "输出目录",
      "type": "directory",
      "arg": "--output",
      "required": true,
      "default": "exports/wps",
      "actions": [
        "export"
      ]
    },
    {
      "name": "request_delay",
      "label": "请求延迟（秒）",
      "type": "number",
      "arg": "--request-delay",
      "default": 0.1,
      "min": 0,
      "step": 0.1,
      "advanced": true,
      "actions": [
        "scan",
        "export"
      ]
    },
    {
      "name": "retry_failed",
      "label": "只重试失败项",
      "type": "checkbox",
      "arg": "--retry-failed",
      "default": false,
      "advanced": true,
      "actions": [
        "export"
      ]
    }
  ],
  "actions": [
    {
      "id": "login",
      "kind": "login",
      "label": "登录 WPS 并保存认证",
      "script": "../../backend/export_wps.py",
      "args": [
        "--login"
      ],
      "track": false,
      "secondary": true
    },
    {
      "id": "scan",
      "kind": "scan",
      "label": "扫描我的云文档",
      "script": "../../backend/export_wps.py",
      "args": [
        "--scan-toc"
      ],
      "includeSelection": false,
      "secondary": true
    },
    {
      "id": "export",
      "kind": "export",
      "label": "开始导出",
      "script": "../../backend/export_wps.py",
      "args": [
        "--progress-every",
        "1"
      ],
      "progressTitle": "WPS 云文档导出",
      "progressDetail": "正在保留目录层级并下载原始文件..."
    },
    {
      "id": "clearAuth",
      "kind": "custom",
      "label": "清除 WPS 登录状态",
      "script": "../../backend/export_wps.py",
      "args": [
        "--clear-auth"
      ],
      "track": false,
      "secondary": true,
      "danger": true,
      "confirm": "这会删除本机保存的 WPS 登录状态，不会删除已导出文件。确定继续吗？"
    }
  ]
}
