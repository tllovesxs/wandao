{
  "schemaVersion": 1,
  "id": "yinxiang",
  "platform": "yinxiang",
  "name": "印象笔记",
  "title": "印象笔记导出",
  "navLabel": "印象笔记导出",
  "description": "同步印象笔记后按笔记本导出 Markdown、图片和附件。",
  "type": "automation",
  "group": "export",
  "trustLevel": "official",
  "status": "stable",
  "templateId": "template-yinxiang",
  "defaults": { "output": "exports/yinxiang" },
  "capabilities": { "export": true, "import": false, "guide": false, "login": true, "scanToc": true, "images": true, "attachments": true, "tree": true, "batch": true, "retryFailures": true },
  "checkpoint": { "supported": true, "strategy": "items", "resourceTracking": false },
  "retryFailures": { "arg": "--retry-failed", "label": "只重试失败项" },
  "toc": { "adapter": "yinxiang-notebooks", "itemsPath": "notebooks", "selectionArg": "--doc-id" },
  "fields": [
    { "name": "username", "label": "印象笔记账号", "type": "text", "arg": "--username", "actions": ["initAuth"] },
    { "name": "database", "label": "本地同步库", "type": "file", "arg": "--database", "advanced": true, "actions": ["scan", "export"] },
    { "name": "output", "label": "输出目录", "type": "directory", "arg": "--output", "required": true, "history": "path", "actions": ["export"] },
    { "name": "incremental", "label": "增量导出", "type": "checkbox", "arg": "--incremental", "default": true, "advanced": true, "actions": ["export"] },
    { "name": "retry_failed", "label": "只重试失败项", "type": "checkbox", "arg": "--retry-failed", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "no_sync", "label": "导出前不重新同步", "type": "checkbox", "arg": "--no-sync", "default": false, "advanced": true, "actions": ["export"] }
  ],
  "actions": [
    { "id": "initAuth", "kind": "login", "label": "初始化凭证并同步", "script": "../../backend/export_yinxiang.py", "args": ["--init-auth", "--password-stdin"], "track": false, "secondary": true },
    { "id": "scan", "kind": "scan", "label": "读取笔记本目录", "script": "../../backend/export_yinxiang.py", "args": ["--scan-toc"], "includeSelection": false, "secondary": true },
    { "id": "export", "kind": "export", "label": "开始导出", "script": "../../backend/export_yinxiang.py", "args": ["--progress-every", "1"], "progressTitle": "印象笔记导出", "progressDetail": "正在同步并转换笔记..." }
  ]
}
