{
  "schemaVersion": 1,
  "id": "youdao",
  "platform": "youdao",
  "name": "有道云笔记",
  "title": "有道云笔记导出",
  "navLabel": "有道云笔记导出",
  "description": "读取有道云笔记目录并导出 Markdown、图片和附件。",
  "type": "automation",
  "group": "export",
  "trustLevel": "official",
  "status": "stable",
  "templateId": "template-youdao",
  "defaults": { "output": "exports/youdao" },
  "capabilities": { "export": true, "import": false, "guide": false, "login": true, "scanToc": true, "images": true, "attachments": true, "tree": true, "batch": true, "retryFailures": true },
  "checkpoint": { "supported": true, "strategy": "items", "resourceTracking": false },
  "retryFailures": { "arg": "--retry-failed", "label": "只重试失败项" },
  "toc": { "itemsPath": "nodes", "idKey": "nodeId", "exportIdKey": "exportId", "titleKey": "title", "parentIdKey": "parentNodeId", "selectableKey": "selectable", "selectionArg": "--doc-id", "selectableWhenExportId": false },
  "fields": [
    { "name": "output", "label": "输出目录", "type": "directory", "arg": "--output", "required": true, "actions": ["export"] },
    { "name": "incremental", "label": "增量导出", "type": "checkbox", "arg": "--incremental", "default": true, "advanced": true, "actions": ["export"] },
    { "name": "update_existing", "label": "更新已有文档", "type": "checkbox", "arg": "--update-existing", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "retry_failed", "label": "只重试失败项", "type": "checkbox", "arg": "--retry-failed", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "request_delay", "label": "请求延迟秒", "type": "number", "arg": "--request-delay", "default": 0.8, "min": 0, "step": 0.1, "advanced": true, "actions": ["export"] },
    { "name": "request_jitter", "label": "随机浮动秒", "type": "number", "arg": "--request-jitter", "default": 0.4, "min": 0, "step": 0.1, "advanced": true, "actions": ["export"] }
  ],
  "actions": [
    { "id": "login", "kind": "login", "label": "登录并保存凭证", "script": "../../backend/export_youdao.py", "args": ["--login"], "track": false, "secondary": true },
    { "id": "scan", "kind": "scan", "label": "读取目录", "script": "../../backend/export_youdao.py", "args": ["--scan-toc"], "includeSelection": false, "secondary": true },
    { "id": "export", "kind": "export", "label": "开始导出", "script": "../../backend/export_youdao.py", "args": ["--progress-every", "1"], "progressTitle": "有道云笔记导出", "progressDetail": "正在导出笔记、图片和附件..." }
  ]
}
