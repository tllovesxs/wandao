{
  "schemaVersion": 1,
  "id": "zsxq-column",
  "platform": "zsxq",
  "name": "知识星球",
  "title": "知识星球专栏导出",
  "navLabel": "知识星球专栏导出",
  "description": "读取知识星球专栏目录并按章节导出 Markdown、图片和附件。",
  "type": "automation",
  "group": "export",
  "trustLevel": "official",
  "status": "stable",
  "templateId": "template-zsxq-column",
  "urlParam": "--entry-url",
  "noUrl": false,
  "defaults": { "output": "exports/zsxq-column" },
  "capabilities": { "export": true, "import": false, "guide": false, "login": true, "scanToc": true, "images": true, "attachments": true, "tree": true, "batch": true, "retryFailures": true },
  "checkpoint": { "supported": true, "strategy": "items", "resourceTracking": true },
  "retryFailures": { "arg": "--retry-failed", "label": "只重试失败项" },
  "toc": { "adapter": "zsxq-column-groups", "itemsPath": "groups", "selectionPrefixArgs": ["--toc-mode", "toc"], "selectionArg": "--toc-key" },
  "fields": [
    { "name": "entry_url", "label": "知识星球专栏 URL", "type": "text", "arg": "--entry-url", "required": true, "history": "url", "actions": ["login", "scan", "export"] },
    { "name": "output", "label": "输出目录", "type": "directory", "arg": "--output", "required": true, "history": "path", "actions": ["export"] },
    { "name": "incremental", "label": "增量导出", "type": "checkbox", "arg": "--incremental", "default": true, "advanced": true, "actions": ["export"] },
    { "name": "update_existing", "label": "更新已有文档", "type": "checkbox", "arg": "--update-existing", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "retry_failed", "label": "只重试失败项", "type": "checkbox", "arg": "--retry-failed", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "follow_link_scope", "label": "正文内链接跟进", "type": "select", "arg": "--follow-link-scope", "default": "none", "options": [{ "value": "none", "label": "不自动跟进（推荐）" }, { "value": "articles", "label": "仅文章正文链接" }, { "value": "all", "label": "所有知识星球链接（较易触发风控）" }], "advanced": true, "actions": ["export"] },
    { "name": "max_depth", "label": "正文链接最大跟进层数", "type": "number", "arg": "--max-depth", "default": 1, "min": 0, "advanced": true, "actions": ["export"] },
    { "name": "request_delay", "label": "请求延迟秒", "type": "number", "arg": "--request-delay", "default": 3, "min": 1, "step": 0.1, "advanced": true, "actions": ["export"] },
    { "name": "request_jitter", "label": "随机浮动秒", "type": "number", "arg": "--request-jitter", "default": 1, "min": 0, "step": 0.1, "advanced": true, "actions": ["export"] },
    { "name": "include_comments", "label": "导出可见评论（快速）", "type": "checkbox", "arg": "--include-comments", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "fetch_full_comments", "label": "完整导出评论（较慢，可能触发风控）", "type": "checkbox", "arg": "--fetch-full-comments", "default": false, "advanced": true, "actions": ["export"] },
    { "name": "download_files", "label": "下载附件", "type": "checkbox", "arg": "--download-files", "default": false, "advanced": true, "actions": ["export"] }
  ],
  "actions": [
    { "id": "login", "kind": "login", "label": "登录并保存凭证", "script": "../../backend/export_zsxq.py", "args": ["--login"], "track": false, "secondary": true },
    { "id": "scan", "kind": "scan", "label": "读取专栏目录", "script": "../../backend/export_zsxq.py", "args": ["--scan-toc"], "includeSelection": false, "secondary": true },
    { "id": "export", "kind": "export", "label": "开始导出", "script": "../../backend/export_zsxq.py", "args": ["--resume"], "progressTitle": "知识星球专栏导出", "progressDetail": "正在导出章节、正文和资源..." }
  ]
}
