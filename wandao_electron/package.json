{
  "name": "wandao",
  "version": "1.2.8",
  "description": "Wandao multi-platform document conversion tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node --check main.js && node --check preload.js && node --check renderer/app.js && node --check renderer/providers.js && node --check renderer/provider_runtime.js && node --check renderer/task_report.js && node --check renderer/structured_logs.js && node --check scripts/npm_install_cn.js",
    "install:cn": "node scripts/npm_install_cn.js",
    "prepare:python": "python scripts/prepare_python_runtime.py --target auto",
    "prepare:python:win": "python scripts/prepare_python_runtime.py --target win-x64",
    "prepare:python:mac:x64": "python scripts/prepare_python_runtime.py --target mac-x64",
    "prepare:python:mac:arm64": "python scripts/prepare_python_runtime.py --target mac-arm64",
    "build:win": "npm run prepare:python:win && electron-builder --win --publish never",
    "build:mac": "npm run prepare:python && electron-builder --mac --publish never",
    "build:mac:x64": "npm run prepare:python:mac:x64 && electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "npm run prepare:python:mac:arm64 && electron-builder --mac --arm64 --publish never",
    "build:all": "npm run build:win"
  },
  "keywords": [
    "knowledge-base",
    "export",
    "feishu",
    "markdown",
    "import",
    "wandao"
  ],
  "author": "tllovesxs",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tllovesxs/wandao.git"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.wandao.app",
    "productName": "Wandao",
    "electronDist": "node_modules/electron/dist",
    "publish": [
      {
        "provider": "github",
        "owner": "tllovesxs",
        "repo": "wandao"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "plugin_format.js",
      "plugin_manager.js",
      "assets/**/*",
      "renderer/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../export_zsxq.py",
        "to": "python/export_zsxq.py"
      },
      {
        "from": "../export_yuque.py",
        "to": "python/export_yuque.py"
      },
      {
        "from": "../import_yuque.py",
        "to": "python/import_yuque.py"
      },
      {
        "from": "../export_aliyun_thoughts.py",
        "to": "python/export_aliyun_thoughts.py"
      },
      {
        "from": "../export_yinxiang.py",
        "to": "python/export_yinxiang.py"
      },
      {
        "from": "../export_youdao.py",
        "to": "python/export_youdao.py"
      },
      {
        "from": "../export_onenote.py",
        "to": "python/export_onenote.py"
      },
      {
        "from": "../import_yinxiang.py",
        "to": "python/import_yinxiang.py"
      },
      {
        "from": "../ima_knowledge.py",
        "to": "python/ima_knowledge.py"
      },
      {
        "from": "../gui_utils.py",
        "to": "python/gui_utils.py"
      },
      {
        "from": "../wandao_logging.py",
        "to": "python/wandao_logging.py"
      },
      {
        "from": "../wandao_report.py",
        "to": "python/wandao_report.py"
      },
      {
        "from": "../wandao_checkpoint.py",
        "to": "python/wandao_checkpoint.py"
      },
      {
        "from": "../wandao_cli.py",
        "to": "python/wandao_cli.py"
      },
      {
        "from": "../wandao_credentials.py",
        "to": "python/wandao_credentials.py"
      },
      {
        "from": "../wandao_browser.py",
        "to": "python/wandao_browser.py"
      },
      {
        "from": "../requirements.txt",
        "to": "python/requirements.txt"
      },
      {
        "from": "../providers",
        "to": "providers",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "runtime/python-runtime",
        "to": "python-runtime"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wandao",
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    }
  },
  "type": "commonjs"
}
